{
  "name": "nemorathwald.com",
  "version": "1.0.0",
  "description": "The website of board game designer Nemo Rathwald.",
  "main": "index.js",
  "scripts": {
    "sass": "sass --style=compressed scss/main.scss css/main.css",
    "build": "npm run sass && eleventy",
    "watch:eleventy": "eleventy --serve",
    "watch:sass": "npm run sass -- --watch",
    "start": "npm-run-all sass --parallel watch:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MattArnold/nemorathwald.com.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/MattArnold/nemorathwald.com/issues"
  },
  "homepage": "https://github.com/MattArnold/nemorathwald.com#readme",
  "devDependencies": {
    "@11ty/eleventy": "^0.11.1",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "sass": "^1.32.8"
  }
}
